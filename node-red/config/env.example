# Telegram runtime metadata
TNSN_TELEGRAM_BOT_NAME=tnsn_control_bot
TNSN_TELEGRAM_POLL_INTERVAL=300

# Signal and audit storage
TNSN_SIGNAL_HISTORY_PATH=/opt/tnsn/logs/signal-history.jsonl
TNSN_AUDIT_LOG_PATH=/opt/tnsn/logs/audit.jsonl

# Existing service endpoints
TNSN_C2_URL=http://127.0.0.1:1880/api/c2
TNSN_AGENT_URL=http://127.0.0.1:1880/nexus/agent/run

# Node-RED admin API location
TNSN_NODE_RED_API=http://127.0.0.1:1880

# Allowed Telegram command surface
TNSN_ALLOWED_COMMANDS=/status,/signals
